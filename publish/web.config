<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <location path="." inheritInChildApplications="false">
<configuration>
    <system.webServer>
        <httpErrors errorMode="Detailed" />
        <aspNetCore processPath="dotnet" arguments=".\MyExcelApp.dll" stdoutLogEnabled="true" stdoutLogFile=".\logs\stdout" hostingModel="inprocess" />
    </system.webServer>

</configuration>
  </location>